                "type": "text"
              }
            ],
            "url": {
              "raw": "{{n8n_api_base_url}}/workflows/{{wf_b_id}}/activate",
              "host": [
                "{{n8n_api_base_url}}"
              ],
              "path": [
                "workflows",
                "{{wf_b_id}}",
                "activate"
              ]
            },
            "description": "Ativa o workflow B por API."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('WF B ativo', function () {",
                  "  pm.expect(json.active).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
