    {
      "name": "1 - WF A (Importacao CSV)",
      "item": [
        {
          "name": "WF A - Import 1 Row (Success)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin_name\": \"{{origin_name}}\",\n  \"product_name\": \"{{product_name}}\",\n  \"product_value\": {{product_value}},\n  \"list_tag_name\": \"{{list_tag_name}}\",\n  \"clint_api_token\": \"{{clint_api_token}}\",\n  \"rows\": [\n    {\n      \"Nome\": \"{{unique_name}}\",\n      \"Email\": \"{{unique_email}}\",\n      \"Telefone\": \"{{phone}}\",\n      \"utm source\": \"postman\",\n      \"utm campaign\": \"wf-a-smoke\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhook/clint-import-csv",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "webhook",
                "clint-import-csv"
              ]
            },
            "description": "Executa importacao minima com 1 linha e valida retorno de sucesso."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const ts = Date.now();",
                  "pm.environment.set('unique_email', `teste.postman.${ts}@example.com`);",
                  "pm.environment.set('unique_name', `Teste Postman ${ts}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let json;",
                  "try { json = pm.response.json(); } catch (e) { json = null; }",
                  "",
                  "pm.test('Resposta JSON valida', function () {",
                  "  pm.expect(json).to.be.an('object');",
                  "});",
                  "",
                  "pm.test('Status de negocio esperado', function () {",
                  "  pm.expect(['success', 'partial_success']).to.include(json.status);",
                  "});",
                  "",
                  "pm.test('Processou 1 linha', function () {",
                  "  pm.expect(json.total_linhas).to.eql(1);",
                  "});"
                ]
              }
            }
          ]
        },
